# ============================================================
# GENESIS — Variables de Entorno
# ============================================================
# Copiar este archivo como .env y completar con tus valores reales.
# NUNCA commitear .env al repositorio.

# ============================================================
# LLM PROVIDER (obligatorio al menos uno)
# ============================================================
# Gemini (recomendado — gratis, 15 RPM)
GOOGLE_API_KEY=tu_api_key_de_google_aqui

# Ollama (local, gratuito — fallback si no hay Gemini)
# OLLAMA_URL=http://localhost:11434

# OpenAI (opcional)
# OPENAI_API_KEY=sk-...

# Anthropic (opcional)
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# GENESIS CONFIG
# ============================================================
# Proveedor forzado (auto = selección automática basada en API keys)
# Opciones: auto, gemini, ollama, openai, anthropic
# GENESIS_PROVIDER=auto

# Modelo local para Ollama
# GENESIS_LOCAL_MODEL=medium

# Capas de GPU para modelo local (más = más rápido, más VRAM)
# GENESIS_GPU_LAYERS=50

# Streaming de tokens (true/false)
# GENESIS_STREAMING=true

# Intervalo de heartbeat en minutos (investigación autónoma)
# GENESIS_HEARTBEAT_INTERVAL=10

# Intervalo de backup automático (cada N interacciones, 0 = desactivado)
# GENESIS_BACKUP_INTERVAL=25

# Email (Gmail SMTP) — App Password de 16 chars, NO la contrasena normal
# Cuenta Google > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicaciones
GMAIL_USER=tucuenta@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Lectura de correo (IMAP). Para leer TU casilla, App Password de ESA cuenta.
GMAIL_READ_USER=alexq2005@gmail.com
GMAIL_READ_APP_PASSWORD=xxxx xxxx xxxx xxxx
