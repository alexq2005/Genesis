{
    "name": "Default",
    "description": "Configuración estándar con Gemini Flash (recomendada)",
    "provider": "auto",
    "model": "gemini-2.0-flash",
    "streaming": true,
    "debate_enabled": false,
    "heartbeat_interval_min": 10,
    "auto_backup_interval": 25,
    "max_file_size_mb": 5.0,
    "max_log_files": 3,
    "log_retention_days": 30,
    "temperature": 0.7,
    "max_tokens": 2048
}
