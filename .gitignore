# ============================================================
# GENESIS — .gitignore
# ============================================================

# --- Secretos ---
.env
.env.local
.env.production

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Temporales de prueba / logs sueltos (no commitear) ---
/_*.py
/_*.txt
@*.txt
*AutomationLog*

# --- Virtual Environment ---
venv/
.venv/
env/

# --- Modelos LLM (archivos de 4-8GB, NO commitear) ---
models/*.gguf
models/*.bin
models/*.safetensors
models/.cache/
# Modelos descargables (Vosk STT ~60MB) — documentar descarga en README
models/vosk-*/
# Voces Piper (.onnx, ~60-115MB c/u) — descargables con piper.download_voices
models/piper/
models/*.onnx
models/*.onnx.json

# --- Datos de runtime (se generan al ejecutar) ---
memory_data/
evolution_data/
logs/
backups/
tools_custom/
# CRITICO: perfil del webview contiene Cookies, Login Data e History del usuario
data/
embeddings_data/
generated_media/
generated_docs/
web_data/

# --- Binarios / artefactos que no deben versionarse ---
*.zip
*.mp3
*.wav

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
nul

# --- Archivos temporales ---
*.tmp
*.bak
*.log

# --- Mantener directorios vacios con .gitkeep ---
!models/.gitkeep
!memory_data/.gitkeep
!evolution_data/.gitkeep
!logs/.gitkeep
!backups/.gitkeep
!tools_custom/.gitkeep
!plugins/.gitkeep
